import express from 'express';
import pg from 'pg';
import dotenv from 'dotenv';
dotenv.config();

var app = express();
var PORT = process.env.PORT || 8080;

function fixDbUrl(url) {
  if (!url) return null;
  var parts = url.split('?');
  if (parts.length < 2) return url;
  var params = parts[1].split('&');
  var filtered = [];
  for (var i = 0; i < params.length; i++) {
    if (params[i].indexOf('channel_binding=') !== 0) {
      filtered.push(params[i]);
    }
  }
  return parts[0] + '?' + filtered.join('&');
}

var pool = null;
function getPool() {
  if (!pool) {
    var dbUrl = fixDbUrl(process.env.DATABASE_URL);
    if (!dbUrl) throw new Error('DATABASE_URL is not set');
    pool = new pg.Pool({
      connectionString: dbUrl,
      ssl: { rejectUnauthorized: false }
    });
  }
  return pool;
}

app.get('/health', function(req, res) {
  res.json({ status: 'ok', port: PORT, phase: 'discovery', time: new Date().toISOString() });
});

app.get('/api/schema', async function(req, res) {
  try {
    var p = getPool();
    var rows = await p.query(
      "SELECT table_name, column_name, data_type FROM information_schema.columns WHERE table_schema='public' ORDER BY table_name, ordinal_position"
    );
    var tables = {};
    for (var i = 0; i < rows.rows.length; i++) {
      var r = rows.rows[i];
      if (!tables[r.table_name]) tables[r.table_name] = [];
      tables[r.table_name].push({ column: r.column_name, type: r.data_type });
    }
    var result = [];
    var keys = Object.keys(tables).sort();
    for (var j = 0; j < keys.length; j++) {
      result.push({ table: keys[j], columns: tables[keys[j]] });
    }
    res.json({ table_count: result.length, tables: result });
  } catch (e) {
    console.error('[SCHEMA ERROR]', e.message);
    res.status(500).json({ error: e.message });
  }
});

app.listen(PORT, function() {
  console.log('Discovery server on :' + PORT);
});
